{
  "manifest_version": 3,
  "name": "VerifAI — Hallucination Detector",
  "version": "1.1.0",
  "description": "Universal Hallucination Detector for all websites and AI platforms.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["styles/popup.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
